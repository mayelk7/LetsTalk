@namespace LetsTalk.Client.Views.Components
@using LetsTalk.Client.Services
@using LetsTalk.Shared.ModelsDto
@using LetsTalk.Shared.Api
@using LetsTalk.Shared.Service
@inject LiveKitServiceClient LiveKit
@inject IJSRuntime JS
@implements IDisposable
@using System.Timers

@code {
    [Parameter]
    public required ChannelDto Channel { get; set; }
    
    private List<ParticipantLiveKit> _participants = new();
    private Timer? _timer;
    private bool _isFirstLoad = true;
    private bool _isConnected = false;
    private bool _isMuted = false;
    
    // ✅ Input temporaire pour l'identité utilisateur
    private string _tempUserId = "";
    
    public async Task getParticipant()
    {
        var response = await ApiManagerService.MakeGetRequest<List<ParticipantLiveKit>>("/api/voice/" + Channel.Name + "/members");
        
        if (response != null && response.Success)
        {
            _participants = response.Data ?? new List<ParticipantLiveKit>();
            Console.WriteLine($"J'ai récupéré {_participants.Count} membres.");
            
            // ✅ Synchroniser avec l'UI JavaScript
            if (_isConnected)
            {
                await JS.InvokeVoidAsync("livekitInterop.updateParticipantsList", _participants);
            }
        }
    }
    
    protected override async Task OnInitializedAsync()
    {
        // Premier chargement immédiat
        await getParticipant();
        _isFirstLoad = false;
        // Configuration d'un timer pour rafraîchir toutes les 5 secondes
        _timer = new Timer(10000);
        _timer.Elapsed += async (sender, e) => await InvokeAsync(RefreshData);
        _timer.AutoReset = true;
        _timer.Enabled = true;
    }
    
    private async Task RefreshData()
    {
        await getParticipant();
        if (_isConnected)
        {
            await JS.InvokeVoidAsync("livekitInterop.clearAllSpeaking");
        }
        StateHasChanged();
    }
    
    // ✅ Rejoindre l'appel
    private async Task JoinCall()
    {
        if (string.IsNullOrWhiteSpace(_tempUserId))
        {
            Console.WriteLine("⚠️ Entrez un nom d'utilisateur");
            return;
        }
        
        var token = LiveKit.GenerateAccessToken(Channel.Name, _tempUserId);
        
        await JS.InvokeVoidAsync(
            "livekitInterop.join",
            "ws://172.20.11.16:7880",
            token,
            _tempUserId
        );
        
        _isConnected = true;
        StateHasChanged();
    }
    
    // ✅ Quitter l'appel
    private async Task LeaveCall()
    {
        await JS.InvokeVoidAsync("livekitInterop.leave");
        _isConnected = false;
        _isMuted = false;
        StateHasChanged();
    }
    
    // ✅ Toggle Mute
    private async Task ToggleMute()
    {
        _isMuted = !_isMuted;
        await JS.InvokeVoidAsync("livekitInterop.toggleMute", _isMuted);
        StateHasChanged();
    }
    
    public void Dispose()
    {
        _timer?.Dispose();
    }

    private bool _isSharingScreen = false;

    private async Task ToggleScreenShare()
    {
        _isSharingScreen = !_isSharingScreen;
        await JS.InvokeVoidAsync("livekitInterop.toggleScreenShare", _isSharingScreen);
        StateHasChanged();
    }
}

@* ✅ Contrôles VOIP en bas de page *@
<MudPaper Elevation="3" Class="pa-3 mb-4" Style="position: sticky; top: 0; z-index: 100;">
    @if (!_isConnected)
    {
        <MudGrid Spacing="2" Justify="Justify.Center">
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="_tempUserId" 
                              Label="Votre nom (temporaire)" 
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4" Class="d-flex align-center">
                <MudButton Color="Color.Success" 
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Call"
                           OnClick="JoinCall"
                           FullWidth>
                    Rejoindre l'appel vocal
                </MudButton>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudGrid Spacing="2" Justify="Justify.Center">
            <MudItem xs="6">
                <MudIconButton 
                    Icon="@(_isMuted ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)"
                    Color="@(_isMuted ? Color.Error : Color.Success)"
                    Variant="Variant.Filled"
                    Size="Size.Large"
                    OnClick="ToggleMute"
                    Title="@(_isMuted ? "Activer le micro" : "Couper le micro")" />
            </MudItem>
            @* ✅ NOUVEAU : Bouton partage d'écran *@
            <MudItem xs="6">
                <MudIconButton Icon="@(_isSharingScreen? Icons.Material.Filled.StopScreenShare : Icons.Material.Filled.ScreenShare)"
                               Color="@(_isSharingScreen ? Color.Warning : Color.Primary)"
                               Variant="Variant.Filled"
                               Size="Size.Large"
                               OnClick="ToggleScreenShare"
                               Title="@(_isSharingScreen ? "Arrêter le partage" : "Partager l'écran")" />
            </MudItem>
            <MudItem xs="6">
                <MudButton Color="Color.Error" 
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.CallEnd"
                           OnClick="LeaveCall">
                    Quitter
                </MudButton>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@* ✅ Grille des participants *@
<MudBox Class="ma-4">
    <MudGrid Spacing="3" Justify="Justify.FlexStart">
        @foreach (var participant in _participants)
        {
            <MudItem xs="6" sm="4" md="3" lg="2">
                @* ✅ Ajoute une div HTML avec l'id *@
                <div id="participant-card-@participant.Identity" class="participant-card-wrapper">
                    <MudPaper Elevation="2"
                              Class="pa-4 d-flex flex-column align-center participant-card"
                              Style="height: 100%; transition: all 0.2s; border: 2px solid transparent;">

                        <div class="mb-3 position-relative">
                            <MudAvatar Size="Size.Large"
                                       Image="@participant.AvatarUrl"
                                       Alt="@participant.Username"
                                       Class="participant-avatar" />
                            <div id="screen-preview-@participant.Identity"
                                 class="screen-preview"
                                 style="display: none;">
                            </div>

                            <div class="voice-indicator"></div>
                        </div>

                        <MudText Typo="Typo.subtitle2"
                                 Align="Align.Center"
                                 Class="mud-text-secondary font-weight-bold">
                            @participant.Username
                        </MudText>
                    </MudPaper>
                </div>
            </MudItem>
        }
    </MudGrid>
</MudBox>

<style>
    .participant-card-wrapper {
        height: 100%;
    }

    .participant-card {
        position: relative;
        height: 100%;
    }

    /* ✅ Carte quand la personne parle */
    .participant-card-wrapper.speaking .participant-card,
    .participant-card.speaking {
        border-color: #23a559 !important;
        box-shadow: 0 0 15px rgba(35, 165, 89, 0.6) !important;
        background: rgba(35, 165, 89, 0.05) !important;
    }

    .participant-card-wrapper.speaking .participant-avatar,
    .participant-card.speaking .participant-avatar {
        box-shadow: 0 0 20px rgba(35, 165, 89, 0.8);
    }

    .voice-indicator {
        position: absolute;
        bottom: 5px;
        right: 5px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background-color: #949ba4;
        border: 2px solid white;
        transition: all 0.2s;
    }

    .participant-card-wrapper.speaking .voice-indicator,
    .participant-card.speaking .voice-indicator {
        background-color: #23a559;
        animation: pulse 1s infinite;
    }

    
    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.6;
            transform: scale(1.4);
        }
    }
    
    .mute-icon {
        margin-top: 4px;
    }
</style>