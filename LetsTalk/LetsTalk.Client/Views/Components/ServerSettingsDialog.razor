
@using MudBlazor
@using MudBlazor.Services
@using LetsTalk.Shared.ModelsDto
@using LetsTalk.Client.Services;
@inject IDialogService DialogService
@* ^^^ Assure-toi que cette ligne est présente ! *@

<MudDialog>
    <DialogContent>
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Général" Icon="@Icons.Material.Filled.Info">
                <MudStack Spacing="4">
                    <MudTextField Label="Nom du serveur" Variant="Variant.Outlined" @bind-Value="_newServerName" />
                </MudStack>
                @* Optionnel : Bouton de test rapide *@
                <MudButton OnClick="HandleSave" Color="Color.Inherit" Class="mt-4">Sauvegarder nom</MudButton>
            </MudTabPanel>

            <MudTabPanel Text="Rôles" Icon="@Icons.Material.Filled.Shield">
                <MudList T="string">
                    <MudListItem Text="Admin" Icon="@Icons.Material.Filled.Star" IconColor="Color.Warning" />
                    <MudListItem Text="Modérateur" Icon="@Icons.Material.Filled.Security" IconColor="Color.Info" />
                    <MudListItem Text="Membre" Icon="@Icons.Material.Filled.Person" />
                </MudList>
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary">Créer un rôle</MudButton>
            </MudTabPanel>

            <MudTabPanel Text="Permissions" Icon="@Icons.Material.Filled.LockPerson">
                <MudTable Items="@UserPermissions" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                    <HeaderContent>
                        <MudTh>Droit</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Activé</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Droit">@context.Name</MudTd>
                        <MudTd DataLabel="Description">@context.Description</MudTd>
                        <MudTd DataLabel="Activé">
                            <MudSwitch @bind-Value="@context.IsEnabled" Color="Color.Primary" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>

        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        @* On appelle HandleSave qui gère l'API ET la fermeture *@
        <MudButton Color="Color.Primary" OnClick="HandleSave">Enregistrer les modifications</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public FullServerDto serveur { get; set; } = default!;

    private string _newServerName = string.Empty;

    private List<PermissionModel> UserPermissions = new()
    {
        new ("Envoyer des messages", "Autorise l'envoi de texte", true),
        new ("Gérer les canaux", "Autorise la création/suppression", false),
        new ("Expulser des membres", "Droit de modération", false)
    };

    protected override void OnInitialized()
    {
        if (serveur == null)
        {
            serveur = new FullServerDto(1, "Serveur Inconnu", new(), new());
        }
        _newServerName = serveur.Name;
    }

    // Gestion du bouton Annuler avec fallback
    private void Cancel()
    {
        MudDialog.Cancel();   
    }

    // Méthode unifiée pour sauvegarder et fermer
    private async Task HandleSave()
    {
        var success = await SaveToApi();
        if (success)
        {
            // On ferme la dialog seulement si l'API a répondu OK
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private async Task<bool> SaveToApi()
    {
        var updatedServer = new FullServerDto(
            serveur.Id,
            _newServerName,
            serveur.Channels,
            serveur.Users
        );

        var result = await ApiManagerService.MakePutRequest<bool, FullServerDto>(
            $"server/{serveur.Id}",
            updatedServer
        );

        return result?.Success ?? false;
    }

    public class PermissionModel
    {
        public string Name { get; set; }
        public string Description { get; set; }
        public bool IsEnabled { get; set; }

        public PermissionModel(string name, string description, bool isEnabled)
        {
            Name = name;
            Description = description;
            IsEnabled = isEnabled;
        }
    }
}