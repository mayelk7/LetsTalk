@namespace LetsTalk.Client.Views.Components

@if (Channel.Messages.Count != 0)
{
    @foreach(var message in Channel.Messages)
    {
        <MudChat Class="pa-2 mb-2" ChatPosition="ChatBubblePosition.Start">
            <MudChatHeader Name="@message.User.Username" Time="@message.Timestamp.ToString()"></MudChatHeader>
            <MudChatBubble>
                @message.Content
            </MudChatBubble>
        </MudChat>
    }
}
else
{
    <MudText>
        Aucun message !
    </MudText>
}

@code {

    [Parameter]
    public required Channel Channel { get; set; }

}