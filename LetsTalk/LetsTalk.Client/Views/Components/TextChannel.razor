@inject TextChannelViewModel TextChannelVm
@using LetsTalk.Client.Services
@using LetsTalk.Shared.ModelsDto
@using LetsTalk.Shared.Perm
@inject AuthStateService AuthState
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@using MudX
@namespace LetsTalk.Client.Views.Components

<div style="display: flex; flex-direction: column; height: 100%;">

    @* Zone des messages (scrollable) *@
    <div style="flex: 1; display: flex; flex-direction: column-reverse; overflow-y: auto;">
        @if (Channel?.Messages?.Count > 0)
        {
            foreach (var message in Channel.Messages.AsEnumerable().Reverse())
            {
                <MudXChat Class="pa-2 mb-2" ChatPosition="@(message.Sender?.Username == AuthState.CurrentUser?.Username ? ChatBubblePosition.End : ChatBubblePosition.Start)">
                    <MudXChatHeader Name="@(message.Sender?.Username ?? "Inconnu")" Time="@message.Timestamp.ToString()"></MudXChatHeader>
                    <MudXChatBubble>
                        @message.Content
                    </MudXChatBubble>
                </MudXChat>
            }
        }
        else
        {
            <MudText Class="pa-4" Align="Align.Center" Color="Color.Secondary">
                Aucun message — lancez la conversation !
            </MudText>
        }
    </div>

    <div @ref="_inputWrapper">
        @if (_imageDataUrl != null)
        {
            <MudImage Src="@_imageDataUrl"
                      Alt="Image preview"
                      Class="mt-2"
                      Style="margin-left: calc(100% * 0.05);position: fixed; bottom: 80px; max-width: 200px; max-height: 200px;">
            </MudImage>
        }

        <MudTextField T="string" @ref="_mudTextField" @bind-Value="@Value" @bind-Value:after="async () => await SendMessage()"
                      Placeholder="Écrire un message..." MaxLines="32"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Send"
                      OnAdornmentClick="async () => await ValueChanged.InvokeAsync(Value)" FullWidth="true"
                      Class="mt-2" Style="width: 55%; margin-left: 5%; position: fixed; bottom: 20px;"
                      @onkeydown="OnKeyDown" />
    </div>

    <MudFileUpload T="IBrowserFile"
                   Class="mt-2"
                   @bind-Files="File"
                   @bind-Files:after="async () => await OnFileInput()"
                   Style="width: 3%;margin-left: calc(100% * 0.01);position: fixed; bottom:20px;"
                   Accept="image/*">
        <CustomContent>
            <MudFab Color="Color.Success"
                    OnClick="@context.OpenFilePickerAsync"
                    StartIcon="@Icons.Material.Filled.AttachFile" />
        </CustomContent>
        <SelectedTemplate />
    </MudFileUpload>
</div>

@code {
    [Parameter]
    public required ChannelDto Channel { get; set; }

    [Parameter]
    public required string Value { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public required IBrowserFile? File { get; set; }
    [Parameter]
    public EventCallback<IBrowserFile> FileChanged { get; set; }
    [Parameter]
    public required int? Serverid { get; set; }

    private MudTextField<string>? _mudTextField;
    private ElementReference _inputWrapper;
    private string? _imageDataUrl = null;

    protected override void OnInitialized()
    {
        TextChannelVm.PropertyChanged += (_, __) => StateHasChanged();
        base.OnInitialized();
    }

    protected override Task OnInitializedAsync()
    {
        TextChannelVm.InitAsync();
        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("preventEnterDefault", _inputWrapper);
    }

    private async Task SendMessage()


    {
        if (Value != string.Empty && AuthState.CurrentUser!.HasPermission(Serverid ?? 0, ServerPermission.SendMessage))
        {
            await ValueChanged.InvokeAsync(Value);
            Value = string.Empty;
            if (_mudTextField != null)
                await _mudTextField.SetTextAsync(string.Empty);
        }
        else if (Value != string.Empty)
        {
            Snackbar.Add("Vous n'avez pas la permission d'envoyer des messages.", Severity.Warning);
        }

        if (File != null)
        {
            await FileChanged.InvokeAsync(File);
            File = null;
            _imageDataUrl = null;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", ShiftKey: false })
        {
            await SendMessage();
            if (_mudTextField != null)
                await _mudTextField.SetTextAsync(string.Empty);
            StateHasChanged();
        }
    }

    private async Task OnFileInput()
    {
        if (File != null)
        {
            var format = File.ContentType;
            var resizedImage = await File.RequestImageFileAsync(format, 100, 100);
            var buffer = new byte[resizedImage.Size];
            await resizedImage.OpenReadStream().ReadAsync(buffer);
            _imageDataUrl = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
        }
    }
}