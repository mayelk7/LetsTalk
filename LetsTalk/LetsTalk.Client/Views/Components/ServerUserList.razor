@using LetsTalk.Shared.ModelsDto
@namespace LetsTalk.Client.Views.Components

<MudStack AlignItems="AlignItems.Start" Class="pl-2 pt-2" Spacing="2">
    @foreach (var user in Users)
    {
        <MudText>@user.Username</MudText>
    }

</MudStack>

@code {
    [Parameter]
    public required List<UserDto> Users { get; set; }
    [Parameter]
    public required int CurrentUserId { get; set; }
    [Inject]
    IDialogService DialogService { get; set; } = default!;

    void OpenCardProfil(UserDto user)
    {
        var parameters = new DialogParameters
        {
            ["User"] = user,
            ["CurrentUserId"] = CurrentUserId
        };
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            Position = DialogPosition.Center
        };
        DialogService.Show<CarteProfilUser>($"Profil de {user.Username}", parameters, options);
    }
}