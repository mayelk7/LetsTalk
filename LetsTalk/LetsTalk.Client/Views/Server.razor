@inject IDialogService DialogService
@inject ServerViewModel ServerVm
@inject NavigationManager NavigationManager
@inject AuthStateService AuthState
@page "/server/{ServerId}"

@using LetsTalk.Client.Views.Components
@using LetsTalk.Shared.Enum
@using LetsTalk.Client.Services
@using LetsTalk.Shared.ModelsDto

@if (ServerVm.Server is not null)
{
    <MudGrid Spacing="0" Style="height: calc(100vh - 80px);">
        <MudItem Xs="2" Class="mud-border-left">
            <MudCard Style="border-radius: 0;">
                <MudCardHeader>
                    <CardHeaderActions>
                        <h2> @ServerVm.Server.Name
                        <MudMenu Icon="@Icons.Material.Filled.KeyboardArrowDown" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="OpenServerSettings">Paramètres du serveur</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Disconnect" Color="Color.Error">Quitter le serveur</MudMenuItem>
                        </MudMenu>
                        </h2>
                    </CardHeaderActions>
                </MudCardHeader>
            </MudCard>
            
            <ServerChannelList Serverid="ServerVm.Server.Id" Channels="ServerVm.Server.Channels" @bind-SelectedChannel="ServerVm.SelectedChannel"/>
        </MudItem>
        <MudItem Xs="8" Class="mud-border-right mud-border-left border-x-2" 
                 Style="border-color: var(--mud-palette-divider);">
            
                 <MudCard Style="border-radius: 0;" Elevation="0" Class="mud-border-bottom">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            @(ServerVm.SelectedChannel?.ChannelType == ChannelType.Text ? "TextChannel" : "VoiceChannel") - @ServerVm.SelectedChannel?.Name
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
            </MudCard>
            
            <MudStack Style="max-height: calc(100vh - 200px); overflow-y: auto;">
                @switch (ServerVm.SelectedChannel?.ChannelType)
                {
                    case ChannelType.Text:
                        <TextChannel Channel="ServerVm.SelectedChannel" UserContext="ServerVm.UserContext" @bind-Value="ServerVm.CurrentMessage" @bind-Value:after="ServerVm.OnMessageInput"/>
                        break;
                    case ChannelType.Voice:
                        <VoiceChannel Channel="ServerVm.SelectedChannel"/>
                        break;
                    case null:
                        break;
                    default:
                        throw new ArgumentOutOfRangeException();
                }
            </MudStack>
            
        </MudItem>
        <MudItem Xs="2" Class="mud-border-right">
            <MudCard Style="border-radius: 0;">
                <MudCardHeader>
                    <h2>Utilisateur - @ServerVm.Server.Users.Count</h2>
                </MudCardHeader>
            </MudCard>

            <ServerUserList Users="@ServerVm.Server.Users" CurrentUserId="@(ServerVm.UserContext.CurrentUser?.Id ?? 0)" />
        </MudItem>
    </MudGrid>
}
else
{
    <MudText>
        Une erreur est survenue lors du chargement du serveur.
    </MudText>
}

@code {
    [Parameter]
    public required string ServerId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (int.TryParse(ServerId, out var serverId))
        {
            await ServerVm.InitAsync(serverId);
        }
        else
        {
            // TODO: Error handling for invalid ServerId
        }

        await base.OnParametersSetAsync();
    }

    protected override void OnInitialized()
    {
        ServerVm.PropertyChanged += (_, __) => StateHasChanged();

        base.OnInitialized();
    }

    private async Task OpenServerSettings()
    {

        // 1. Créer les paramètres
        var parameters = new DialogParameters<ServerSettingsDialog>();

        // 2. Ajouter les données (le nom doit correspondre exactement au [Parameter] dans le dialogue)
        parameters.Add(x => x.serveur, ServerVm.Server);

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

        var dialog = await DialogService.ShowAsync<ServerSettingsDialog>("Paramètres du Serveur",parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled)
        {
            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }


    }



    private async Task Disconnect()
    {
        var userId = AuthState.CurrentUser.UtilisateurId;
        string useridtostring = userId.ToString();
        Console.WriteLine($"UserId envoyé: {useridtostring}");

        var result = await ApiManagerService.MakePutRequest<bool, LeaveServerRequestdto>(
            $"user/servers/{ServerId}/leave",
            new LeaveServerRequestdto { UserId = useridtostring }
    );

        if (result != null && result.Success)
            NavigationManager.NavigateTo("/home");
    }
}
