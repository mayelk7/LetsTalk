@page "/2fa"
@layout LetsTalk.Client.Views.Layout.LoginLayout
@using MudBlazor
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Double Authentification</PageTitle>

<MudContainer Square="true" Class="mud-height-full mud-width-full d-flex align-center justify-center pa-6" style="height: 80vh;">
    <MudPaper Outlined="true" Elevation="12" Class="pa-10" Width="450px">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">

            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                <MudIcon Icon="@Icons.Material.Filled.Security" />
            </MudAvatar>

            <MudText Typo="Typo.h4" Align="Align.Center">Vérification</MudText>

            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                Entrez le code à 6 chiffres de votre application de sécurité.
            </MudText>

            <MudForm @ref="_form" Class="mud-width-full">
                <MudTextField @bind-Value="_authCode"
                              Label="Code secret"
                              Variant="Variant.Outlined"
                              MaxLength="6"
                              HelperText="Ex: 123456"
                              InputType="InputType.Number"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.PhonelinkLock"
                              Class="mb-6"
                              AutoFocus="true"
                              Clearable="true"
                              Disabled="_isLoading" />

                <MudButton FullWidth="true"
                           Size="Size.Large"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SimulateSubmit"
                           Disabled="_isLoading || _authCode?.Length != 6">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ml-2">Validation...</MudText>
                    }
                    else
                    {
                        <span>Vérifier le code</span>
                    }
                </MudButton>

                <MudButton FullWidth="true"
                           Variant="Variant.Text"
                           Color="Color.Secondary"
                           Class="mt-2"
                           OnClick="@(() => Navigation.NavigateTo("/login"))">
                    Retour à la connexion
                </MudButton>
            </MudForm>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private MudForm? _form;
    private string _authCode = "";
    private bool _isLoading;

    private async Task SimulateSubmit()
    {
        _isLoading = true;

        // Simulation d'un délai réseau de 1.5 seconde
        await Task.Delay(1500);

        // Simulation d'une logique simple pour le test
        if (_authCode == "123456")
        {
            Snackbar.Add("Code correct ! Connexion en cours...", Severity.Success);
            _isLoading = false;

            // Redirection vers l'accueil
            Navigation.NavigateTo("/");
        }
        else
        {
            Snackbar.Add("Code erroné (Astuce : tapez 123456)", Severity.Error);
            _authCode = "";
            _isLoading = false;
        }
    }
}