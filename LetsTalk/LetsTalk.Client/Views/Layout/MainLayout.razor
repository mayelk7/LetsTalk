@inherits LayoutComponentBase
@inject MainLayoutViewModel MainLayoutVm

<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h5" Class="ml-3">Let's Talk</MudText>
        <MudSpacer />
        <MudInput T="string" @bind-Value="@MainLayoutVm.Search" Immediate="true" Variant="Variant.Filled"></MudInput>
        <MudSpacer />
        <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle" />
        <MudIconButton Icon="@Icons.Material.Filled.SupervisedUserCircle" Color="Color.Inherit" />
    </MudAppBar>
    
    <MudDrawer id="nav-drawer"
               ClipMode="DrawerClipMode.Docked"
               OverlayAutoClose="false"
               Variant="DrawerVariant.Mini"
               Open="false"
               Anchor="Anchor.Start"
               Elevation="1">
        <MudNavMenu>
    
            @if (MainLayoutVm.MenuItems is not null)
            {
                foreach (var item in MainLayoutVm.MenuItems)
                {
                    <MudNavLink Href="@item.Href" Match="NavLinkMatch.All" Icon="@item.Icon">@item.Title</MudNavLink>
                }

            }
            else
            {
                <MudText>Loading...</MudText>
            }


            @* <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="ml-auto"> *@
            @*     <MudIcon Icon="@Icons.Material.Filled.Add"/> *@
            @* </MudButton> *@

        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16">
        @Body
    </MudMainContent>
</MudLayout>


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private MudTheme? _theme = null;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        
        MainLayoutVm.PropertyChanged += (_, __) => StateHasChanged();

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties()
        };
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Primary = "#7C3AED",
        Secondary = "#6D28D9",

        Background = "#F8FAFC",
        Surface = "#FFFFFF",
        AppbarBackground = "#FFFFFF",
        AppbarText = "#111827",
        DrawerBackground = "#FFFFFF",
        DrawerText = "#111827",
        TextPrimary = "#111827",
        TextSecondary = "#6B7280",
        ActionDefault = "#7C3AED",
        LinesDefault = "#E5E7EB",
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#9225A6",
        Secondary = "#CA58E0",
        Background = "#1A1A27",
        Surface = "#1E1A2B",
        AppbarBackground = "#070512",
        AppbarText = "#EAE9F1",
        DrawerBackground = "#1E1A2B",
        DrawerText = "#B9B6C8",
        TextPrimary = "#EAE9F1",
        TextSecondary = "#B9B6C8",
        ActionDefault = "#8C869E",
        LinesDefault = "#5C5B5F33"
    };
    Typography Typography => new()
    {
        Default = new DefaultTypography()
        {
            FontFamily = new[] { "Inter", "SF Pro Text", "Segoe UI", "Roboto", "system-ui", "sans-serif" },
            FontSize = "15px"
        },
        H1 = new H1Typography() { FontSize = "28px", FontWeight = "600", LetterSpacing = "-0.2px" },
        H2 = new H2Typography() { FontSize = "22px", FontWeight = "600", LetterSpacing = "-0.2px" },
        H3 = new H3Typography() { FontSize = "18px", FontWeight = "600" },
        Body1 = new Body1Typography() { FontSize = "15px", FontWeight = "400", LineHeight = "1.6" },
        Body2 = new Body2Typography() { FontSize = "13px", FontWeight = "400", LineHeight = "1.4" },
        Caption = new CaptionTypography() { FontSize = "11px", FontWeight = "400", LetterSpacing = "0.2px" }
    };
    
    private string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Rounded.AutoMode,
        false => Icons.Material.Outlined.DarkMode,
    };
}


