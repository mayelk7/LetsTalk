@page "/reset-password"
@layout LetsTalk.Client.Views.Layout.LoginLayout
@using LetsTalk.Client.Services
@using MudBlazor
@using LetsTalk.Shared.ModelsDto
@using LetsTalk.Shared.Api
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthStateService AuthState

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center">Nouveau mot de passe</MudText>

        <MudForm @ref="_form">
            <MudTextField T="string" Label="Nouveau mot de passe"
                          @bind-Value="_newPassword"
                          InputType="@_passwordInput"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordInputIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Required="true" />

            <MudTextField T="string" Label="Confirmer le mot de passe"
                          @bind-Value="_confirmPassword"
                          InputType="InputType.Password"
                          Validation="@(new Func<string, string?>(p => p != _newPassword ? "Les mots de passe ne correspondent pas" : null))"
                          Required="true" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       Class="mt-6" OnClick="Submit" Disabled="@_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
                else
                {

                    @("Réinitialiser")
                }
            </MudButton>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    [Parameter][SupplyParameterFromQuery] public string? Token { get; set; }

    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _isLoading;
    private MudForm? _form;

    // Gestion visibilité mot de passe
    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    void TogglePasswordVisibility()
    {
        if (_passwordVisibility)
        {
            _passwordVisibility = false;
            _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _passwordVisibility = true;
            _passwordInputIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    private async Task Submit()
    {
        await _form!.Validate();
        if (!_form.IsValid) return;
        if (string.IsNullOrEmpty(Token))
        {
            Snackbar.Add("Token manquant ou invalide.", Severity.Error);
            return;
        }

        _isLoading = true;
        try
        {
            var dto = new { Token = Token, NewPassword = _newPassword };
            var response = await Http.PostAsJsonAsync("api/auth/reset-password", dto);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Mot de passe modifié ! Connectez-vous.", Severity.Success);
                Navigation.NavigateTo("/login");
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ApiResponse<UserAuthDto>>();
                Snackbar.Add(error?.Message ?? "Erreur inconnue", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add("Erreur : " + ex.Message, Severity.Error); }
        finally { _isLoading = false; }
    }
}