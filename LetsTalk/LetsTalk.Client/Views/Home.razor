@page "/home"
@inject MainLayoutViewModel MainLayoutVm
@using LetsTalk.Client.ViewModels

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    @* 1. Header de bienvenue *@
    <div class="d-flex align-center mb-8">
        <MudAvatar Color="Color.Primary" Style="height:70px; width:70px; font-size:2rem;" Class="mr-4">
            @(MainLayoutVm.AuthState.CurrentUser?.Username?.Substring(0, 1).ToUpper() ?? "U")
        </MudAvatar>
        <div>
            <MudText Typo="Typo.h3">Ravi de vous revoir, @(MainLayoutVm.AuthState.CurrentUser?.Username ?? "invité") !</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Prêt à discuter avec votre communauté ?</MudText>
        </div>
    </div>

    <MudGrid>
        @* 2. Cartes d'actions rapides *@
        <MudItem Xs="12" Sm="6" Md="4">
            <MudCard Elevation="4" Class="py-4 px-2 flex-column d-flex align-center justify-center hover-card" Style="cursor:pointer; height: 100%;">
                <MudIcon Icon="@Icons.Material.Rounded.Groups" Color="Color.Primary" Size="Size.Large" />
                <MudCardContent>
                    <MudText Typo="Typo.h6" Align="Align.Center">Mes Serveurs</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center">Retrouvez vos @(MainLayoutVm.MenuItems.Count - 2) communautés.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem Xs="12" Sm="6" Md="4">
            <MudCard Elevation="4" Class="py-4 px-2 flex-column d-flex align-center justify-center hover-card" Style="cursor:pointer; height: 100%;">
                <MudIcon Icon="@Icons.Material.Rounded.AddCircle" Color="Color.Secondary" Size="Size.Large" />
                <MudCardContent>
                    <MudText Typo="Typo.h6" Align="Align.Center">Nouveau Serveur</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center">Créez un espace pour vos amis.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem Xs="12" Sm="6" Md="4">
            <MudCard Elevation="4" Class="py-4 px-2 flex-column d-flex align-center justify-center hover-card" Style="cursor:pointer; height: 100%;">
                <MudIcon Icon="@Icons.Material.Rounded.Settings" Color="Color.Info" Size="Size.Large" />
                <MudCardContent>
                    <MudText Typo="Typo.h6" Align="Align.Center">Paramètres</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center">Gérez votre profil et vos notifications.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* 3. Section d'actualités / Log des mises à jour *@
        <MudItem Xs="12" Md="8">
            <MudPaper Elevation="2" Class="pa-6">
                <MudText Typo="Typo.h5" Class="mb-4">Dernières nouvelles</MudText>
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    <MudTimelineItem Color="Color.Success" Size="Size.Small">
                        <MudText Typo="Typo.button">Aujourd'hui</MudText>
                        <MudText Typo="Typo.body2">Lancement de la version stable de LetsTalk !</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="Color.Info" Size="Size.Small">
                        <MudText Typo="Typo.button">Hier</MudText>
                        <MudText Typo="Typo.body2">Amélioration de la fluidité des messages texte.</MudText>
                    </MudTimelineItem>
                </MudTimeline>
            </MudPaper>
        </MudItem>

        @* 4. Petit Widget latéral *@
        <MudItem Xs="12" Md="4">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Rounded.TipsAndUpdates">
                <MudText Typo="Typo.subtitle2">Astuce du jour :</MudText>
                <MudText Typo="Typo.body2">Utilisez la barre de recherche en haut pour trouver vos amis plus rapidement.</MudText>
            </MudAlert>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
        }
</style>