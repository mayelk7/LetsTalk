@page "/NewServer"
@layout LetsTalk.Client.Views.Layout.LoginLayout
@using LetsTalk.Client.Services
@using MudBlazor
@using LetsTalk.Shared.ModelsDto
@using LetsTalk.Shared.Api
@using LetsTalk.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthStateService AuthState


<PageTitle>Créer un Serveur</PageTitle>

<MudThemeProvider Theme="@Theme" IsDarkMode="true" />

<MudContainer MaxWidth="MaxWidth.False"
              Class="mud-width-full d-flex flex-column pa-6"
              Style="min-height: 100vh; overflow-y: auto;">

    <MudSpacer />

    <MudContainer MaxWidth="MaxWidth.Large"
                  Class="d-flex align-center justify-center"
                  Style="width: 100%;">

        <MudPaper Outlined="true"
                  Elevation="12"
                  Class="pa-10"
                  Style="width: 100%; max-width: 1400px; margin: 0 auto; border-radius: 32px;">

            <MudGrid Spacing="0">
                <MudItem xs="12" md="6" Class="d-flex align-center justify-center pa-8">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Size="Size.Large" Color="Color.Primary" Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.Group" />
                        </MudAvatar>

                        <MudText Typo="Typo.h3">Let's Talk</MudText>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="6" Class="d-flex align-center justify-center pa-8">
                    <MudPaper Elevation="8"
                              Class="pa-8"
                              Style="width: 100%; max-width: 420px; max-height: 80vh; overflow-y: auto; border-radius: 24px;">

                        <MudText Typo="Typo.h4" Class="mb-6">Créer un compte</MudText>

                        <MudForm>
                            <MudTextField @bind-Value="_servername"
                                          Label="ServerName"
                                          Variant="Variant.Filled"
                                          Margin="Margin.Dense"
                                          FullWidth="true"
                                          Required="true"
                                          Immediate="true"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Person"
                                          Class="mb-4"
                                          Disabled="_isLoading" />

                            <MudSelect T="int"
                                       Label="Membres"
                                       MultiSelection="true"
                                       Class="mb-4"
                                       @bind-SelectedValues="_selectedUserIds">
                                @foreach (var user in alluser)
                                {
                                    <MudSelectItem T="int" Value="@((int)user.Id!)">@user.Username</MudSelectItem>
                                }
                            </MudSelect>

                            <MudButton FullWidth="true"
                                       Size="Size.Large"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="Submit"
                                       Disabled="_isLoading">
                                @if (_isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <MudText Class="ml-2">Creation en Cours</MudText>
                                }
                                else
                                {
                                    <span>Crée un Nouveau Server</span>
                                }
                            </MudButton>
                        </MudForm>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>

    <MudSpacer />
</MudContainer>

@code {
    private List<UserDto> alluser = new();
    private IEnumerable<int> _selectedUserIds = new HashSet<int>();
    private MudForm? _form;
    private bool _isLoading;
    private string? _servername;
    private string? _phone;
    private string? _email;
    private string? _password;
    private string? _confirmPassword;
    private string? _errorMessage;
    private bool _showPassword;
    private bool _showConfirmPassword;

    private async Task<List<UserDto>> GetAllUsersAsync()
    {
        try
        {
            // Appel direct à l'API
            var response = await Http.GetAsync("http://localhost:5278/api/user");

            if (!response.IsSuccessStatusCode)
            {
                Console.WriteLine($"Erreur API : {response.StatusCode}");
                return new List<UserDto>();
            }

            var content = await response.Content.ReadAsStringAsync();

            // Vérification rapide si ce n’est pas du JSON
            if (content.TrimStart().StartsWith("<"))
            {
                Console.WriteLine("Attention : La réponse n'est pas du JSON !");
                Console.WriteLine(content);
                return new List<UserDto>();
            }

            // Désérialisation du JSON
            var apiResponse = System.Text.Json.JsonSerializer.Deserialize<ApiResponse<List<UserDto>>>(
                content,
                new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                }
            );

            return apiResponse?.Data ?? new List<UserDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erreur lors du chargement des utilisateurs : " + ex.Message);
            return new List<UserDto>();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        alluser = await GetAllUsersAsync();

        // Pour debug
        Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(alluser));
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPassword()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_servername)) return;

        _isLoading = true;

        var dto = new CreateServerDto(
            _servername,
            AuthState.CurrentUser.UtilisateurId,         // l'id de l'utilisateur connecté
            _selectedUserIds.ToList()           // ta liste de membres sélectionnés
        );

        var response = await Http.PostAsJsonAsync("http://localhost:5278/api/server", dto);

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Serveur créé !", Severity.Success);
            Navigation.NavigateTo("/");
        }
        else
        {
            Snackbar.Add("Erreur lors de la création.", Severity.Error);
        }

        _isLoading = false;
    }

    private MudTheme Theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#7b2ff7",
            Secondary = "#f107a3",
            Background = "#0f0f1a",
            Surface = "#1a1a2e",
            TextPrimary = "#ffffff",
            TextSecondary = "rgba(255,255,255,0.70)"
        }
    };
}
