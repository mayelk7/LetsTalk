@page "/counter"
@inject CounterViewModel Vm


<PageTitle>Counter</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Counter</MudText>

<MudText Class="mb-4">Current count: @Vm.CurrentCount</MudText>

<MudButton Color="Color.Primary" Variant="Variant.Filled" @onclick="Vm.IncrementCountCommand.Execute">Click me</MudButton>

@code {

    protected override void OnInitialized()
    {
        Vm.PropertyChanged += (_, __) => StateHasChanged();
        
        base.OnInitialized();
    }
}
