@page "/forgot-password"
@layout LetsTalk.Client.Views.Layout.LoginLayout
@using LetsTalk.Client.Services
@using MudBlazor
@using LetsTalk.Shared.ModelsDto
@using LetsTalk.Shared.Api
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthStateService AuthState

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center">Mot de passe oublié</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">Saisissez votre email pour recevoir un lien de réinitialisation.</MudText>

        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudTextField T="string" Label="Email" Required="true"
                          InputType="InputType.Email"
                          @bind-Value="_email"
                          Validation="@(new EmailAddressAttribute() {ErrorMessage = "Email invalide"})" />

            <div class="d-flex align-center justify-space-between mt-6">
                <MudButton Variant="Variant.Text" Color="Color.Primary" Link="/login">Retour</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(!_success || _isLoading)"
                           OnClick="Submit">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {

                        @("Envoyer le lien")
                    }
                </MudButton>
            </div>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private bool _success;
    private bool _isLoading;
    private string _email = "";
    private MudForm? _form;

    private async Task Submit()
    {
        _isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", new { Email = _email });
            // On affiche un succès même si l'email n'existe pas (sécurité)
            Snackbar.Add("Si cet email existe, un lien a été envoyé.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Erreur lors de l'envoi : " + ex.Message, Severity.Error);
        }
        finally { _isLoading = false; }
    }
}
